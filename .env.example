# Copy this file to .env and fill in your values
# Never commit .env to version control

SECRET_KEY=change-this-to-a-long-random-string

# Email (optional — app works without it, notifications just won't send)
# For Gmail: enable 2FA and create an App Password at myaccount.google.com/apppasswords
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your@gmail.com
MAIL_PASSWORD=your-16-char-app-password
MAIL_DEFAULT_SENDER=your@gmail.com

# Database (set automatically by Railway/Render — leave blank for local SQLite)
# DATABASE_URL=postgresql://user:pass@host/dbname
